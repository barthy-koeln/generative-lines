---
/**
  * Chat input component with text field and send button.
  * Dispatches custom events for user interaction.
  */
import AButton from './AButton.astro'

export interface Props {
  id?: string
  placeholder?: string
  disabled?: boolean
}

const {
  id,
  placeholder = 'Type your message...',
  disabled = false
} = Astro.props
---

<form
  class="AChatInput"
  id={id}
>
  <textarea
    class="AChatInput__field"
    placeholder={placeholder}
    name="message"
    autocomplete="off"
    disabled={disabled}
  />
  <AButton
    type="submit"
    class="AChatInput__button"
    disabled={disabled}
  >
    Send
  </AButton>
</form>

<style lang="scss">
  @use "../../variables" as *;

  .AChatInput {
    width: 100%;
    max-width: 600px;
    position: relative;
  }

  .AChatInput__field {
    padding: var(--spacer-sm);
    padding-bottom: var(--spacer-lg);
    font-size: var(--fontsize-4);
    background: var(--color-black);
    border: 1px solid var(--color-white);
    color: var(--color-white);
    outline: none;
    transition: border-color var(--anim-duration) var(--anim-easing);
    width: 100%;
    height: 100%;
    resize: none;
    min-height: 10lh;

    &::placeholder {
      color: var(--color-white);
      opacity: 0.5;
    }

    &:focus {
      border-color: var(--color-accent);
    }

    &:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
  }

  .AChatInput__button {
    white-space: nowrap;
    position: absolute;
    bottom: var(--spacer-sm);
    right: var(--spacer-sm);
  }
</style>
