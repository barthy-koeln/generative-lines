---
---

<canvas class="AThinkingCanvas"/>

<script>
  import { useRenderer } from '../../lib/renderer.ts'
  import { getScale } from 'color2k'
  import { createStepsInterpolator } from '../../lib/utils/interpolators.ts'
  import { Easing } from '@tweenjs/tween.js'

  const canvasElement = document.querySelector<HTMLCanvasElement>('.AThinkingCanvas')!
  const context = canvasElement.getContext('2d')
  if (!context) {
    throw new Error('2D context not available')
  }

  const renderer = useRenderer(canvasElement, context)

  const colorScales = [
    getScale('#1fd125', '#a30fba'),
    getScale('#a5de5f', '#f05e54'),
    getScale('#cdd14d', '#3446ba'),
  ]

  const getSteps = createStepsInterpolator(16)

  let animationFrame: ReturnType<typeof requestAnimationFrame> | null = null
  let lastFrame: DOMHighResTimeStamp = 0.0
  let duration: number = 8_000
  let delta: number = 0.0
  let timeProgress: number = 0.0
  let progress: number = 0.0
  let thickness: number = 2
  let distance: number = 4
  const isThinking = {
    _value: false,
    set value (newValue: boolean) {
      this._value = newValue

      canvasElement?.setAttribute('data-is-thinking', String(this._value))
    },
    get value () {
      return this._value
    }
  }

  function getColors (offset: number) {
    const colors = []
    for (let i = 0; i < colorScales.length; i++) {
      colors[i] = colorScales[i](offset)
    }

    return colors
  }

  function moveToward (now: number, target: number, delta: number, duration: number) {
    if (now === target) return now

    return now + (target - now) * (delta / duration)
  }

  function animate (timestamp: DOMHighResTimeStamp) {
    delta = lastFrame ? timestamp - lastFrame : 0.0
    if (delta > 500) {
      timeProgress = 0
      lastFrame = timestamp
      queueFrame()
      return
    }

    timeProgress += delta * (isThinking.value ? 4 : 1)
    if (timeProgress > duration) {
      timeProgress -= duration
    }

    thickness = moveToward(thickness, isThinking.value ? 4 : 2, delta, 250)
    progress = Math.cos((timeProgress / duration) * Math.PI * 2)
    distance = moveToward(distance, 4 + ((isThinking.value ? 16 : 4) * (progress + 1)), delta, 250)
    renderer.mergeConfig({
      distance,
      thickness
    })
    renderer.mergeState({
      colors: getColors(progress),
      steps: getSteps(progress),
    })
    lastFrame = timestamp
    queueFrame()
  }

  function queueFrame () {
    animationFrame = requestAnimationFrame(animate)
  }

  async function renderInitialState () {
    await renderer.animate({ from: renderer.getCurrentSegment(), to: [0.4, 0.6] })
  }

  function startThinkingAnimation () {
    if (isThinking.value) {
      return
    }

    isThinking.value = true
    renderer.animate({ from: renderer.getCurrentSegment(), to: [0.0, 1.0] })
  }

  async function stopThinkingAnimation () {
    if (!isThinking.value) {
      return
    }

    isThinking.value = false
    await renderInitialState()
  }

  renderer.initialize({
    distance: 4,
    amplitude: 24,
    thickness,
    lines: 8,
    paddingX: 16,
    paddingY: 16,
    perspective: 0.01,
    background: '#181818',
    animationDuration: 800,
    easing: Easing.Quadratic.InOut
  }, { colors: getColors(0.0), steps: getSteps(0.0) })

  renderer.drawSegment(0.5, 0.5)
  renderInitialState()
  queueFrame()

  canvasElement.addEventListener('astro:thinking:start', startThinkingAnimation)
  canvasElement.addEventListener('astro:thinking:stop', stopThinkingAnimation)
</script>

<style lang="scss">
  @use "../../variables" as *;

  .AThinkingCanvas {
    width: 100%;
    aspect-ratio: 1;
    transform: translate(0, -25%);
    transition: transform var(--anim-duration) var(--anim-easing);

    @media (min-height: 800px) {
      transform: translate(0, 0);
    }

    &[data-is-thinking="true"] {
      transform: translate(0, 0);
    }
  }
</style>
