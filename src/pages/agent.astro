---
import '../root.scss'
import '../demo.scss'
import '@fontsource/ubuntu/latin-400.css'
import '@fontsource/ubuntu/latin-700.css'
import AThinkingCanvas from '../components/atoms/AThinkingCanvas.astro'
import AChatInput from '../components/atoms/AChatInput.astro'
import ONavbar from '../components/organisms/ONavBar.astro'
---

<html lang="en">
<head>
  <meta charset="utf-8"/>
  <link
    rel="icon"
    type="image/svg+xml"
    href="/favicon.svg"
  />
  <meta
    name="viewport"
    content="width=device-width"
  />
  <meta
    name="generator"
    content={Astro.generator}
  />
  <title>Generative Lines</title>
</head>
<body>
<div class="AgentThinking">
  <ONavbar/>

  <AThinkingCanvas/>

  <div class="AgentThinking__input-container">
    <p class="AgentThinking__subtitle">How can I help today?</p>

    <AChatInput id="chat-form"/>
  </div>
</div>
</body>
<script>

  if ('virtualKeyboard' in navigator) {
    navigator.virtualKeyboard.overlaysContent = true
  }

  const MOCK_RESPONSES = [
    // 'That\'s an interesting perspective. Let me think about that for a moment...',
    // 'I\'ve processed your request. Here\'s what I found based on the available information.',
    'Great question! The answer involves several factors working together.',
    // 'I understand what you\'re asking. Based on my analysis, here\'s my response.',
    // 'Thanks for sharing that. Here\'s my take on the matter.',
  ]

  function getRandomResponse (): string {
    return MOCK_RESPONSES[Math.floor(Math.random() * MOCK_RESPONSES.length)]
  }

  const form = document.querySelector<HTMLFormElement>('#chat-form')
  const canvas = document.querySelector<HTMLElement>('.AThinkingCanvas')
  const messageElement = document.querySelector<HTMLElement>('.AgentThinking__subtitle')

  const isThinking = {
    _value: false,
    set value (newValue: boolean) {
      this._value = newValue

      if (messageElement) {
        messageElement.setAttribute('data-is-thinking', String(this._value))
        if (this._value) {
          messageElement.innerText = '*Thinking*'
        }
      }
    },
    get value () {
      return this._value
    }
  }

  function handleSubmit (event: Event) {

    if (!form || !canvas) {
      throw new Error('Required elements not found')
    }

    event.preventDefault()

    if (isThinking.value) {
      return
    }

    const formData = new FormData(form)
    const message = String(formData.get('message'))

    if (!message.trim()) {
      return
    }

    isThinking.value = true
    const inputField = form.querySelector<HTMLTextAreaElement>('textarea')
    if (inputField) {
      inputField.disabled = true
    }

    canvas.dispatchEvent(new CustomEvent('astro:thinking:start'))

    setTimeout(() => {
      canvas.dispatchEvent(new CustomEvent('astro:thinking:stop'))

      if (messageElement) {
        messageElement.innerText = getRandomResponse()
      }

      if (inputField) {
        inputField.disabled = false
        inputField.value = ''
        inputField.focus()
      }

      isThinking.value = false
    }, 6_000)
  }

  if (!form) {
    throw new Error('Required elements not found')
  }

  form.addEventListener('submit', handleSubmit)
</script>

<style lang="scss">
  @use "../variables" as *;

  body {
    background: var(--color-black);
    color: var(--color-white);
    height: 100svh;
  }

  .AgentThinking {
    flex-direction: column;
    align-items: self-start;
    width: 100%;
    display: flex;
    max-width: 800px;
    height: 100svh;
    margin: auto;
    overflow: hidden;
    position: relative;

    @include desktop() {
      max-height: 1024px;
    }
  }

  h1 {
    font-size: var(--fontsize-1);
    color: var(--color-white);
    margin: 0;
    text-align: center;
  }

  .AgentThinking__subtitle {
    opacity: 1;
    transform: translate(0, 0);
    width: 100%;
    transition: var(--anim-duration) var(--anim-easing);
    transition-property: opacity, transform;
    text-align: center;
    height: 2lh;

    @media (min-height: 800px) {
      font-size: var(--fontsize-3);
      max-width: 35ch;
    }
  }

  .AgentThinking__subtitle[data-is-thinking="true"] {
    opacity: .2;
    transform: translate(0, 32px);
  }

  .AgentThinking__input-container {
    width: calc(100% - 2 * var(--spacer));
    max-width: 600px;
    display: flex;
    gap: var(--spacer-lg);
    justify-content: flex-start;
    align-items: center;
    flex-direction: column;
    grid-area: keyboard;
    position: absolute;
    bottom: calc(var(--spacer) + env(keyboard-inset-height, 0px));
    left: 50%;
    transform: translateX(-50%);
  }
</style>
