---
import '../root.scss'
import '@fontsource/ubuntu/latin-400.css'
import '@fontsource/ubuntu/latin-700.css'
import OLineCanvasForm from '../components/organisms/OLineCanvasForm.astro'
import Layout from '../layouts/Layout.astro'
import AButton from '../components/atoms/AButton.astro'
import MDemoLinks from '../components/molecules/MDemoLinks.astro'
---

<Layout>
  <h1>Generative Lines</h1>

  <p>Beautiful lightweight animations, usable as loading throbbers or scroll-in animations.</p>

  <MDemoLinks current="playground"/>

  <hr>

  <OLineCanvasForm>
    <lines-canvas
      class="demo"
      autoplay="false"
    />

    <div>
      <AButton id="download-button">Download</AButton>
      <AButton id="animation-button">Replay animation</AButton>
    </div>
  </OLineCanvasForm>

  <hr>

  <p>All downloads of “Generative Lines” by <a
    href="https://github.com/barthy-koeln"
    target="_blank"
  >Barth&eacute;l&eacute;my&nbsp;Bonhomme</a> are licensed under <a
    href="https://creativecommons.org/licenses/by/4.0/"
    target="_blank"
    rel="nofollow noopener"
  >CC&nbsp;BY&nbsp;4.0</a>.</p>
  <p>Contact me if you use it, I'd love to see what you do!</p>
</Layout>

<script>
  import { LinesCanvas } from '../lib/lines-canvas.ts'
  import { download } from '../lib/utils/file.ts'

  customElements.define('lines-canvas', LinesCanvas)

  const downloadButton = document.querySelector<HTMLButtonElement>('#download-button')
  const animationButton = document.querySelector<HTMLButtonElement>('#animation-button')
  const linesCanvas = document.querySelector<LinesCanvas>('lines-canvas')
  if (!linesCanvas) {
    throw new Error('LinesCanvas element not found')
  }

  const form = document.querySelector<HTMLFormElement>('form')
  if (!form) {
    throw new Error('Form element not found')
  }

  const data = new FormData(form)
  linesCanvas.startBatchUpdate()
  for (const [key, value] of data.entries()) {
    linesCanvas.setAttribute(key, value.toString())
  }
  linesCanvas.endBatchUpdate()

  linesCanvas.renderer.animateIn()

  if (!downloadButton) {
    throw new Error('Download button or lines canvas not found')
  }

  downloadButton.addEventListener('click', () => {
    download(linesCanvas)
  })

  if (!animationButton) {
    throw new Error('Animation animation not found')
  }

  animationButton.addEventListener('click', async () => {
    await linesCanvas.renderer.animateWipeOut()
    await linesCanvas.renderer.animateIn()
  })
</script>

<style>
  .demo {
    display: block;
    width: 100%;
    aspect-ratio: 1;
  }
</style>
