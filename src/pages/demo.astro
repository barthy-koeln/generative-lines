---
import Layout from '../layouts/Layout.astro'
---

<Layout dark>
  <h1>Generative Lines</h1>

  <p>Procedural line art that responds to your scroll (don't read the text)</p>

  <p><a href="/">Playground</a> | <a href="/docs">Use it as a library</a></p>

  <hr>

  <section class="intro">
    <lines-canvas
      animation-duration="2000"
      lines="32"
      thickness="2"
      easing="Sinusoidal.InOut"
      animation-easing="Cubic.Out"
      distance="8"
      amplitude="96"
      perspective="0.02"
      padding-x="0"
      padding-y="0"
      autoplay="false"
      tween-group="demo"
      color-values="#33ff33,#bada55,white,#bada55,#33ff33"
      step-values="-1.0,0.5,0.0,0.0,-0.5,1.0"
    />
  </section>

  <section class="pattern">
    <lines-canvas
      animation-duration="1500"
      steps="6"
      lines="16"
      colors="2"
      thickness="3"
      easing="Quadratic.InOut"
      animation-easing="Quadratic.Out"
      distance="4"
      amplitude="32"
      perspective="0.01"
      padding-x="0"
      padding-y="0"
      autoplay="false"
      tween-group="demo"
    />
    <div class="text-content">
      <h2>Geometric Harmony</h2>
      <p>
        The lines dance in rhythmic patterns, each vertex calculated from Sinusoidal waves
        layered in superposition. The distance parameter controls the spacing between
        consecutive points along each curve, while amplitude determines their maximum
        deviation from the baseline. Perspective adds subtle depth, making foreground
        lines appear larger than their distant counterparts.
      </p>
    </div>
  </section>

  <section class="pattern reverse">
    <div class="text-content">
      <h2>Volumetric Depth</h2>
      <p>
        By varying the number of colors and line thickness, we achieve different visual
        weights. Thinner lines create delicate, ethereal patterns, while thicker strokes
        convey bold geometric statements. The color count parameter interpolates between
        discrete hues, creating smooth gradients that shift as the animation progresses.
        This volumetric approach mimics how light interacts with layered transparent surfaces.
      </p>
    </div>
    <lines-canvas
      animation-duration="1800"
      steps="10"
      lines="40"
      colors="8"
      thickness="2"
      easing="Linear.InOut"
      animation-easing="Bounce.Out"
      distance="6"
      amplitude="16"
      perspective="0.01"
      padding-x="0"
      padding-y="0"
      autoplay="false"
      tween-group="demo"
    />
  </section>

  <section class="pattern">
    <lines-canvas
      animation-duration="2500"
      steps="8"
      lines="24"
      colors="4"
      thickness="2"
      easing="Circular.InOut"
      animation-easing="Sinusoidal.Out"
      distance="3"
      amplitude="64"
      padding-x="0"
      padding-y="0"
      perspective="0.015"
      autoplay="false"
      tween-group="demo"
    />
    <div class="text-content">
      <h2>Temporal Flow</h2>
      <p>
        Easing functions govern both the geometric evolution and the animation timing.
        Bounce eases create sudden stops and rebounds, elastic eases introduce overshoot
        oscillations, and circular eases accelerate through the center of the curve.
        The animation duration spans from rapid flashes to languid driftings, each
        creating a distinct temporal rhythm that complements the underlying geometry.
      </p>
    </div>
  </section>

  <section class="pattern reverse">
    <div class="text-content">
      <h2>Chaotic Order</h2>
      <p>
        Despite the apparent randomness, each frame is deterministically computed from
        mathematical functions. The intersection observer triggers animations when canvases
        enter the viewport, creating a cascading effect as you scroll. The threshold of
        0.8 means animations begin when 80% of the canvas becomes visible, ensuring
        smooth transitions without premature reveals.
      </p>
    </div>
    <lines-canvas
      animation-duration="3000"
      steps="64"
      lines="9"
      colors="6"
      thickness="3"
      easing="Back.InOut"
      animation-easing="Quadratic.Out"
      distance="9"
      amplitude="18"
      padding-x="0"
      padding-y="0"
      perspective="0.025"
      autoplay="false"
      tween-group="demo"
    />
  </section>

  <section class="finale">
    <lines-canvas
      animation-duration="4000"
      steps="20"
      lines="64"
      colors="10"
      thickness="1"
      easing="Quadratic.InOut"
      animation-easing="Quadratic.InOut"
      distance="1"
      amplitude="64"
      perspective="0.01"
      autoplay="false"
      tween-group="demo"
    />
  </section>
</Layout>

<script>
  import { LinesCanvas } from '../lib/lines-canvas.ts'

  customElements.define('lines-canvas', LinesCanvas)

  const observer = new IntersectionObserver(handleIntersection, {
    threshold: [0.01, 0.8],
  })

  function handleIntersection (entries: IntersectionObserverEntry[], observer: IntersectionObserver): void {
    for (const entry of entries) {
      const linesCanvas: Element = entry.target
      if (!(linesCanvas instanceof LinesCanvas)) {
        throw new Error('Entry target is not a LinesCanvas element')
      }

      if (entry.intersectionRatio <= 0.01) {
        if (linesCanvas.dataset.status === 'cleared') {
          continue
        }

        linesCanvas.renderer.clearCanvas()
        linesCanvas.dataset.status = 'cleared'
        continue
      }

      if (linesCanvas.dataset.status === 'animated') {
        continue
      }

      if (linesCanvas.parentElement?.classList.contains('finale')) {
        linesCanvas.renderer.animateLoop()
        linesCanvas.dataset.status = 'animated'
        continue
      }

      if (linesCanvas.parentElement?.firstElementChild === linesCanvas) {
        linesCanvas.renderer.animate({ from: [0, 0], to: [0, 1] })
      } else {
        linesCanvas.renderer.animate({ from: [1, 1], to: [0, 1] })
      }

      linesCanvas.dataset.status = 'animated'
    }
  }

  const canvasses = Array.from(document.querySelectorAll<LinesCanvas>('lines-canvas'))
  const firstCanvas = canvasses.shift()
  if (!firstCanvas) {
    throw new Error('No lines-canvas elements found in the document')
  }

  for (const canvas of canvasses) {
    observer.observe(canvas)
  }

  function animate (time: DOMHighResTimeStamp) {
    const progress = ((time % 8000) / 8000) * Math.PI * 2
    firstCanvas!.renderer.mergeConfig({ distance: 8 * Math.sin(progress) })
    requestAnimationFrame(animate)
  }

  firstCanvas.renderer.animateIn().then(() => {
    requestAnimationFrame(animate)
  })
</script>

<style lang="scss">
  @use "../variables" as *;

  header {
    text-align: center;
    margin-bottom: var(--spacer-lg);

    p {
      color: var(--color-white);
      opacity: 0.7;
      font-size: var(--fontsize-4);
    }
  }

  section {
    display: flex;
    flex-direction: row;
    gap: var(--spacer-xl);
    align-items: center;
    justify-content: center;
    padding: var(--spacer-lg) 0;
  }

  .intro {
    min-height: 50vh;
  }

  .finale {
    min-height: 50vh;
    flex-direction: column;
    text-align: center;
    width: 100%;

    lines-canvas {
      height: 256px;
    }
  }

  lines-canvas {
    width: 100%;
    height: 100%;
    aspect-ratio: 1;
  }

  .text-content {
    flex: 1;
    max-width: 45ch;

    h2 {
      font-size: var(--fontsize-2);
      color: var(--color-white);
      margin-bottom: var(--spacer-sm);
    }

    p {
      color: var(--color-white);
      opacity: 0.85;
      line-height: 1.8;
    }
  }

  .pattern {
    @include desktop {
      lines-canvas {
        width: 40%;
      }
    }
  }

  @media (max-width: var(--bp-desktop)) {
    section {
      flex-direction: column !important;
      gap: var(--spacer-lg);
    }
  }
</style>