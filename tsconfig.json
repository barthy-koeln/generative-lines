{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "types": [
      "astro/client",
      "jest"
    ],
    "ignoreDeprecations": "6.0",
    "isolatedModules": true,
    "rootDir": "./"
  }
}
